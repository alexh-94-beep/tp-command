# ─────────────────────────────────────────────────────────────────────────────
# TP-Command – Umgebungsvariablen
# Kopiere diese Datei nach .env.local und fuelle die Werte fuer die DEV-Umgebung.
# Quelle der Supabase-Werte: Supabase-Dashboard -> Project Settings -> API
# (oder `supabase status` fuer die lokale Instanz).
#
# Umgebungs-Strategie (siehe DEPLOYMENT.md):
#   .env.local / Vercel "Development" + "Preview"  ->  tp-command-dev
#   Vercel "Production"                            ->  tp-command-prod
# ─────────────────────────────────────────────────────────────────────────────

# Supabase – Projekt-URL und Keys
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # NUR serverseitig (Cron/Webhooks), NIE im Client

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_TIMEZONE=Europe/Zurich
APP_CURRENCY=CHF

# Cron-Schutz – Vercel-Cron sendet `Authorization: Bearer <CRON_SECRET>`
CRON_SECRET=

# Flatfox (Phase 3)
FLATFOX_API_TOKEN=
FLATFOX_API_URL=
FLATFOX_WEBHOOK_SECRET=

# Booking.com iCal (Phase 6)
BOOKING_ICAL_USER_AGENT=TP-Command/1.0

# Resend (Phase 10)
RESEND_API_KEY=
