# Supabase – holst du aus dem Supabase-Dashboard oder `supabase status` (lokal)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # NUR Server-seitig nutzen, NIE im Client

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_TIMEZONE=Europe/Zurich
APP_CURRENCY=CHF

# Resend (Phase 4)
RESEND_API_KEY=

# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Cron-Schutz – muss bei /api/cron/* in Header `x-cron-secret` mitgeliefert werden
CRON_SECRET=

# Booking iCal (Phase 3) – pro Wohnung in DB, hier nur globaler Default
BOOKING_ICAL_USER_AGENT=Immoserv/1.0
